# Servidor SMTP (ex: smtp.gmail.com, smtp.office365.com, smtp.zoho.com)
SMTP_HOST=smtp.exemplo.com

# Porta SMTP: 587 (STARTTLS) ou 465 (SSL)
SMTP_PORT=587

# true para 465 (SSL), false para 587 (STARTTLS)
SMTP_SECURE=false

# Credenciais
SMTP_USER=seu-email@exemplo.com
SMTP_PASS=sua-senha-ou-app-password

# Remetente padrão (opcional, usa SMTP_USER se vazio)
SMTP_FROM=seu-email@exemplo.com
SMTP_FROM_NAME=Aurora Bot
